if SHIELD_ENDEFFECTOR_LEFT

# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "EndEffector"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
  default 1

config BT_MAX_CONN
  default 6

config BT_MAX_PAIRED
  default 6

endif

if SHIELD_ENDEFFECTOR_LEFT || SHIELD_ENDEFFECTOR_RIGHT

config ZMK_SPLIT
    default y

endif

if SHIELD_ENDEFFECTOR_DONGLE

# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "EndEffector"

config ZMK_SPLIT
    default y

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
  default 2

config BT_MAX_CONN
  default 7

config BT_MAX_PAIRED
  default 7

endif

# ---------------------
# Kconfig for shield "endeffector_left" with board "nice_nano_v2"
# ---------------------
if BOARD_NICE_NANO_V2 && SHIELD_ENDEFFECTOR_LEFT

config SPI
    default y

endif

# ---------------------
# Kconfig for shield "endeffector_right" with board "nice_nano_v2"
# ---------------------
if BOARD_NICE_NANO_V2 && SHIELD_ENDEFFECTOR_RIGHT

config SPI
    default y

endif
